{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>eleboucher/renovate-config", "github>home-operations/renovate-presets#2.1.0"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.yaml(?:\\.j2)?$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\s+url: \"https://github\\.com/(?:[^/]+/[^/]+)/releases/download/(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "datasourceTemplate": "{{datasource}}",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "Auto merge container digests",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "matchPackageNames": ["ghcr.io/home-operations/**", "ghcr.io/bjw-s-labs/**"],
      "automerge": true
    },
    {
      "description": "Auto merge minors and patches",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "/kube-prometheus-stack/",
        "ghcr.io/mogenius/helm-charts/renovate-operator",
        "ghcr.io/nesquena/hermes-webui",
        "ghcr.io/ggml-org/llama.cpp",
        "ghcr.io/home-operations/charts/konflate",
        "ollama/ollama"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge Renovate Presents",
      "matchManagers": ["renovate-config"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": true
    },
    {
      "description": "Auto-merge high-cadence packages weekly",
      "matchDatasources": ["docker"],
      "automerge": true,
      "matchUpdateTypes": ["digest", "minor", "patch"],
      "matchPackageNames": [
        "ghcr.io/renovatebot/renovate",
        "ghcr.io/cloudnative-pg/postgis-extension-testing",
        "ghcr.io/cloudnative-pg/postgresql",
        "ghcr.io/emberstack/helm-charts/reflector",
        "ghcr.io/mogenius/helm-charts/renovate-operator"
      ],
      "schedule": ["before 6am on Monday"]
    },
    {
      "description": "Flux Operator Group",
      "groupName": "flux-operator",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/flux-operator/", "/flux-instance/"],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 2
    },
    {
      "description": "Intel Device Plugins Group",
      "groupName": "intel-device-plugins",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/intel-device-plugins-operator/", "/intel-device-plugins-gpu/"],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 2
    },
    {
      "description": "kguardian group",
      "groupName": "kguardian",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/kguardian-dev/"],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      }
    },
    {
      "description": "sparkyfitness group",
      "groupName": "sparkyfitness",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/sparkyfitness/"],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      }
    },
    {
      "description": "1Password Connect group",
      "groupName": "1Password Connect",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/1password/"],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 2
    },
    {
      "description": "Kubernetes Group",
      "groupName": "kubernetes",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/"
      ],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 5
    },
    {
      "description": "Toolhive group",
      "groupName": "Toolhive",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/toolhive-operator/"],
      "group": {
        "commitMessageTopic": "{{{groupName}}} group"
      },
      "minimumGroupSize": 2
    },
    {
      "description": "agentmemory uses semver + '-<commit-sha>' tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["registry.erwanleboucher.dev/eleboucher/agentmemory"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-[a-f0-9]+$"
    }
  ]
}
