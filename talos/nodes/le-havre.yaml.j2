---
machine:
  type: worker
  install:
    diskSelector:
      serial: 2526511B4465
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: lan0
selector:
  match: mac(link.permanent_addr) == "6c:1f:f7:6b:4c:04"
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: lan1
selector:
  match: mac(link.permanent_addr) == "6c:1f:f7:5c:03:94"
---
apiVersion: v1alpha1
kind: ExistingVolumeConfig
name: media
discovery:
  volumeSelector:
    match: disk.transport == "usb"
---
apiVersion: v1alpha1
kind: ResolverConfig
nameservers:
  - address: 192.168.1.2
---
apiVersion: v1alpha1
kind: HostnameConfig
auto: "off"
hostname: le-havre
