---
machine:
  type: controlplane
  certSANs:
    - 127.0.0.1
    - 192.168.1.42
  install:
    diskSelector:
      type: nvme
  udev:
    rules:
      - SUBSYSTEM=="drm", KERNEL=="renderD*", GROUP="992", MODE="0660"
---
apiVersion: v1alpha1
kind: VolumeConfig
name: EPHEMERAL
provisioning:
  maxSize: 400GiB
---
# SAMSUNG MZ7KM1T9 (1.92TB SATA SSD) is used whole-disk for the
# OpenEBS ZFS pool (zfspv-pool) — created out-of-band, no Talos volume config.
apiVersion: v1alpha1
kind: ExistingVolumeConfig
name: media
discovery:
  volumeSelector:
    match: disk.transport == "sata" && disk.size > 4000000000000u
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: lan0
selector:
  match: mac(link.permanent_addr) == "c4:62:37:09:df:ff"
---
apiVersion: v1alpha1
kind: BondConfig
name: lacp0
mtu: 9000
links:
  - lan0
bondMode: active-backup
miimon: 100
---
apiVersion: v1alpha1
kind: HostnameConfig
auto: "off"
hostname: paris
