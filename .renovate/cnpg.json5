{
    $schema: "https://docs.renovatebot.com/renovate-schema.json",
    customManagers: [
        {
            description: "Detect CNPG Cluster CRD imageName + extension reference fields",
            customType: "regex",
            managerFilePatterns: ["/kubernetes/apps/database/.+\\.yaml$/"],
            matchStrings: [
                "(?:imageName|reference):\\s+(?<depName>[^:\\s]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
            ],
            datasourceTemplate: "docker",
        },
    ],
    packageRules: [
        {
            description: "vchord-scratch uses 'pg<N>-v<semver>' prefix",
            matchDatasources: ["docker"],
            matchPackageNames: ["ghcr.io/tensorchord/vchord-scratch"],
            versioning: "regex:^pg18-v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
        },
    ],
}
