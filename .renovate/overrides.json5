{
    $schema: "https://docs.renovatebot.com/renovate-schema.json",
    packageRules: [
        {
            description: "agentmemory uses semver + '-<commit-sha>' tags",
            matchDatasources: ["docker"],
            matchPackageNames: ["registry.erwanleboucher.dev/eleboucher/agentmemory"],
            versioning: "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-[a-f0-9]+$",
        },
    ],
}
